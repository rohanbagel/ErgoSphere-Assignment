DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database engine: use sqlite now; switch to mysql later when ready.
DB_ENGINE=sqlite

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# For MySQL later, set DB_ENGINE=mysql and fill these.
MYSQL_DB=
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model-name

CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=book_chunks

SCRAPER_BASE_URL=https://books.toscrape.com/
SCRAPER_DEFAULT_MAX_PAGES=5
