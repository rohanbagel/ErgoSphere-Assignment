DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database engine: use sqlite now; switch to mysql later when ready.
DB_ENGINE=sqlite

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# For MySQL later, set DB_ENGINE=mysql and fill these.
MYSQL_DB=
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model-name
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=book_chunks

# Chroma mode: local or cloud
CHROMA_MODE=local

# Chroma Cloud (required when CHROMA_MODE=cloud)
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

SCRAPER_BASE_URL=https://books.toscrape.com/
SCRAPER_DEFAULT_MAX_PAGES=5
